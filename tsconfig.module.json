{
    "extends": "@ekz/packer/tsconfig/recommended",
    "compilerOptions": {
        "lib": [
            "dom",
            "dom.iterable",
            "es6"
        ],
        "noEmit": false,
        "declaration": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "noFallthroughCasesInSwitch": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "pretty": true,
        "removeComments": false,
        "sourceMap": true,
        "stripInternal": true,
        "typeRoots": [
            "./node_modules/@types"
        ],
        "verbatimModuleSyntax": true
    }
}
