{
  "name": "@ekz/async-data",
  "version": "1.0.1",
  "license": "MIT",
  "description": "Async data wrapper for promises",
  "homepage": "https://docs.ekz.io/async-data/",
  "repository": {
    "type": "git",
    "url": "https://github.com/erkez/ekz.git",
    "directory": "async-data"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "esnext": "lib/esnext/index.js",
  "typings": "lib/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./extractors": {
      "types": "./lib/esm/extractors.d.ts",
      "import": "./lib/esm/extractors.js",
      "require": "./lib/cjs/extractors.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "async",
    "promise",
    "option",
    "type-safe"
  ],
  "dependencies": {
    "@ekz/option": "^2.0.1",
    "luxon": "^3.7.2"
  },
  "peerDependencies": {
    "@ekz/option": "^2.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.2",
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "clean": "rm -rf lib/* || true",
    "lint": "npx eslint ./src/main/web",
    "lint:fix": "yarn lint --fix",
    "compile": "run-p \"compile:*\"",
    "compile:esm": "tsc -p ./src/main/web --outDir ./lib/esm",
    "compile:cjs": "tsc -p ./src/main/web -m commonjs --verbatimModuleSyntax false --outDir ./lib/cjs",
    "compile:esnext": "tsc -p ./src/main/web -t esnext --outDir ./lib/esnext",
    "dev": "yarn compile:esm --watch",
    "test": "yarn typecheck:tests && jest",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "prepack": "yarn test && yarn lint && yarn compile"
  },
  "jest": {
    "preset": "ts-jest/presets/default",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/main/web"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}
