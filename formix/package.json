{
  "name": "@ekz/formix",
  "version": "2.0.0",
  "license": "MIT",
  "description": "Type-safe React form to be used with Typescript",
  "repository": {
    "type": "git",
    "url": "https://github.com/erkez/ekz.git",
    "directory": "formix"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "esnext": "lib/esnext/index.js",
  "typings": "lib/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "form",
    "formix",
    "typescript",
    "type-safe"
  ],
  "peerDependencies": {
    "@ekz/option": "^2.0.0",
    "immutable": "^4 || ^5",
    "react": "^16.8.0 || ^17 || ^18 || ^19",
    "typescript": "^4 || ^5"
  },
  "devDependencies": {
    "@ekz/option": "workspace:^",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "18.3.28",
    "immutable": "^5.1.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "clean": "rm -rf lib/* || true",
    "lint": "npx eslint --ext .ts --ext .tsx ./src/main/web",
    "lint:fix": "yarn lint --fix",
    "compile": "run-p \"compile:*\"",
    "compile:esm": "tsc -p ./src/main/web --outDir ./lib/esm",
    "compile:cjs": "tsc -p ./src/main/web -m commonjs --verbatimModuleSyntax false --outDir ./lib/cjs",
    "compile:esnext": "tsc -p ./src/main/web -t esnext --outDir ./lib/esnext",
    "test": "jest",
    "prepublish": "yarn clean && yarn test --ci --no-watchman && yarn lint && yarn compile"
  },
  "jest": {
    "preset": "ts-jest/presets/default",
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react"
          }
        }
      ]
    }
  }
}
