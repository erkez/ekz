{
  "name": "@ekz/blueprintjs",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erkez/ekz.git",
    "directory": "blueprintjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "esnext": "lib/esnext/index.js",
  "typings": "lib/esm/index.d.ts",
  "files": [
    "lib"
  ],
  "dependencies": {
    "@blueprintjs/core": "^6.12.1",
    "@blueprintjs/icons": "^6.9.1",
    "@blueprintjs/select": "^6.1.10",
    "@ekz/react-utils": "workspace:^",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tanstack/table-core": "^8.21.3",
    "classnames": "^2.5.1",
    "invariant": "^2.2.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/bluebird": "^3.5.42",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "1.77.8",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19",
    "react-dom": "^18.3.1 || ^19"
  },
  "scripts": {
    "clean": "rm -rf dist/* || rm -rf lib/* || true",
    "lint": "npx eslint --ext .ts --ext .tsx ./src/main/web",
    "lint:fix": "yarn lint --fix",
    "compile": "run-p \"compile:*\"",
    "compile:esm": "tsc -p ./src/main/web --outDir ./lib/esm",
    "compile:cjs": "tsc -p ./src/main/web -m commonjs --verbatimModuleSyntax false --outDir ./lib/cjs",
    "compile:esnext": "tsc -p ./src/main/web -t esnext --outDir ./lib/esnext",
    "compile:css": "sass --load-path=node_modules --load-path=../node_modules --load-path=../../../node_modules src/main/web:lib/css",
    "dev": "yarn compile:esm --watch",
    "prepublish": "yarn clean && yarn lint && yarn compile"
  }
}
