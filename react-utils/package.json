{
  "name": "@ekz/react-utils",
  "version": "1.0.0",
  "license": "MIT",
  "description": "React hooks and utilities",
  "homepage": "https://docs.ekz.io/react-utils/",
  "repository": {
    "type": "git",
    "url": "https://github.com/erkez/ekz.git",
    "directory": "react-utils"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "esnext": "lib/esnext/index.js",
  "typings": "lib/esm/index.d.ts",
  "files": [
    "lib",
    "README.md"
  ],
  "dependencies": {
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bluebird": "^3.5.42",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19",
    "react-dom": "^18.3.1 || ^19"
  },
  "scripts": {
    "clean": "rm -rf dist/* || rm -rf lib/* || true",
    "lint": "npx eslint ./src/main/web",
    "lint:fix": "yarn lint --fix",
    "compile": "run-p \"compile:*\"",
    "compile:esm": "tsc -p ./src/main/web --outDir ./lib/esm",
    "compile:cjs": "tsc -p ./src/main/web -m commonjs --verbatimModuleSyntax false --outDir ./lib/cjs",
    "compile:esnext": "tsc -p ./src/main/web -t esnext --outDir ./lib/esnext",
    "dev": "yarn compile:esm --watch",
    "prepublish": "yarn clean && yarn lint && yarn compile"
  }
}
