{
  "name": "@ekz/api",
  "version": "1.0.3",
  "license": "MIT",
  "description": "HTTP/WebSocket API client for React",
  "homepage": "https://docs.ekz.io/api/",
  "repository": {
    "type": "git",
    "url": "https://github.com/erkez/ekz.git",
    "directory": "api"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "esnext": "lib/esnext/index.js",
  "typings": "lib/esm/index.d.ts",
  "files": [
    "lib",
    "README.md"
  ],
  "dependencies": {
    "@ekz/async-data": "^1.0.1",
    "@ekz/option": "^2.0.1",
    "@ekz/react-utils": "^1.0.1",
    "axios": "^1.18.1",
    "bluebird": "^3.7.2",
    "invariant": "^2.2.4",
    "querystring": "^0.2.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bluebird": "^3.5.42",
    "@types/invariant": "^2.2.37",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.2",
    "immutable": "^5.1.8",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "immutable": "^4 || ^5",
    "react": "^18.3.1 || ^19",
    "react-dom": "^18.3.1 || ^19"
  },
  "scripts": {
    "clean": "rm -rf dist/* || rm -rf lib/* || true",
    "lint": "npx eslint ./src/main/web",
    "lint:fix": "yarn lint --fix",
    "compile": "run-p \"compile:*\"",
    "compile:esm": "tsc -p ./src/main/web --outDir ./lib/esm",
    "compile:cjs": "tsc -p ./src/main/web -m commonjs --verbatimModuleSyntax false --outDir ./lib/cjs",
    "compile:esnext": "tsc -p ./src/main/web -t esnext --outDir ./lib/esnext",
    "dev": "yarn compile:esm --watch",
    "prepack": "yarn clean && yarn lint && yarn compile"
  }
}
