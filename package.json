{
    "name": "ekz",
    "private": true,
    "description": "@ekz libraries",
    "license": "MIT",
    "packageManager": "yarn@4.16.0",
    "workspaces": [
        "option",
        "async-data",
        "react-utils",
        "formix",
        "api",
        "blueprintjs"
    ],
    "scripts": {
        "compile": "yarn workspaces foreach -Apt run compile",
        "lint": "yarn workspaces foreach -Apt run lint",
        "typecheck:tests": "yarn workspaces foreach -Apt --exclude ekz run typecheck:tests",
        "test": "yarn workspaces foreach -Apt --exclude ekz run test",
        "dedupe:check": "yarn dedupe --check"
    },
    "devDependencies": {
        "@ekz/packer": "^1.0.0-beta.4",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25.6.0",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.7",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": "^24.0.0"
    }
}
